<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body class="big-light">
    <div class="container py-5">
        <h2 class="text-center mb-4">Student records</h2>
        <input type="text" id="search" class="form-control mb-4" placeholder="search student">
        <div id="container" class="row g-4"></div>
        </div>
   
    <script>
        const students = [
            { name: "rahul",branch:"cse",cgpa:8.5 },
            { name: "ram",branch:"cse",cgpa:9.5 },
            { name: "raghav",branch:"cse",cgpa:8.9 },
            { name: "siya",branch:"cse",cgpa:7.5 },
            { name: "shyaml",branch:"cse",cgpa:8.8 },
            { name: "raj",branch:"cse",cgpa:8.3 },
            { name: "aman",branch:"cse",cgpa:8.3 },
            { name: "jiya",branch:"cse",cgpa:9.2 },
            { name: "jay",branch:"cse",cgpa:9.0 },
            { name: "ajay",branch:"cse",cgpa:8.8 },
             ];
             let html = "";
             for(let i=0; i<students.length; i++) {
                html += `
             
            <div class="col-md-4 card-item">
                <div class="card shadow">
                    <div class="card-body">
                        <h4>${students[i].name}</h4>
                        <button class="btn btn-primary btn-sm mt-2">
                            show details
                            </button>
                                <div class="details mt-3" style="display:none;">
                                    <p><strong>Branch:</strong>${students[i].branch}</p>
                                    <p><strong>Cgpa:</strong>${students[i].cgpa}</p>
                                     </div>
                                     </div>
                                     </div>
                                     </div>
                                     `;
             }
document.getElementById("container").innerHTML = html;
$(document).on("click",".btn",function(){
    $(this).next(".details").slideToggle();
});
 $("#search").keyup(function(){
    let val = $(this).val().toLowerCase();
    $(".card-item").each(function(){
        let name = $(this).find("h4").text().toLowerCase();
        if(name.includes(val)){
            $(this).show();
        }
        else{
            $(this).hide();
        }
    });
 });

    </script>
</body>
</html>
